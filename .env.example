EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Anthropic (image descriptions on Library upload — see lib/vision.ts)
# EXPO_PUBLIC_ANTHROPIC_API_KEY=

# OpenAI: Action chat (lib/chat.ts), upload moderation (lib/moderation.ts), weekly recap (lib/weeklyRecap.ts)
# EXPO_PUBLIC_OPENAI_API_KEY=

# After pulling: run SQL in supabase/migrations/*weekly*nudge*.sql so chat logging + weekly recap + want_to_do work.

# Embedding sidecar URL — output of `modal deploy embeddings/app.py` (see embeddings/README.md).
# EXPO_PUBLIC_EMBED_SIDECAR_URL=

# Backfill only. Never EXPO_PUBLIC_, never bundled into the RN app.
# SUPABASE_SERVICE_ROLE_KEY=